{
  "manifest_version": 3,
  "name": "Tree Style Tabs",
  "version": "0.1.0",
  "description": "A vertical, nestable tree of tabs with grouping, collapsing, and fast keyboard-friendly navigation.",
  "permissions": ["tabs", "tabGroups", "storage", "sidePanel", "favicon"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Tree Style Tabs",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "minimum_chrome_version": "116"
}
